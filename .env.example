# ============================================================================
# Two modes:
#
# 1. DEMO MODE (no backend needed) — just set this and deploy:
#      NEXT_PUBLIC_DEMO_MODE=true
#    Everything else can be left blank. App runs on hardcoded sample data.
#    Perfect for sharing a Vercel link with management.
#
# 2. REAL MODE — fill in your Supabase project keys. See README.md for the
#    free-tier setup (Postgres + Auth + Storage are all free).
# ============================================================================

# Demo mode toggle — set to 'true' for a no-backend Vercel preview.
NEXT_PUBLIC_DEMO_MODE=true

# Supabase (only needed when DEMO_MODE != 'true')
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# App
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Auth domain restriction (only used in REAL mode)
ALLOWED_EMAIL_DOMAIN=sgtuniversity.org
